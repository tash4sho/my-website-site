---
import '../styles/global.css';
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact - Your Business</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  </head>
  <body class="bg-white text-gray-900" style="font-family: 'Inter', sans-serif;">

    <!-- Header (matches other pages) -->
    <header class="py-10">
      <div class="max-w-7xl mx-auto px-6 flex flex-col items-center gap-8">
        <a href="/" class="text-3xl tracking-widest uppercase" style="font-family: 'Playfair Display', serif;">
          Your Business
        </a>
        <nav class="flex gap-10 text-sm uppercase tracking-widest text-gray-700">
          <a href="/" class="hover:text-black">Home</a>
          <a href="/about" class="hover:text-black">About</a>
          <a href="/services" class="hover:text-black">Services</a>
          <a href="/contact" class="hover:text-black">Contact</a>
        </nav>
      </div>
    </header>

    <!-- Contact section -->
    <section class="max-w-2xl mx-auto px-6 py-28">
      <p class="text-sm uppercase tracking-widest text-gray-500 mb-4 text-center">Get in Touch</p>
      <h1 class="text-5xl mb-6 text-center leading-tight" style="font-family: 'Playfair Display', serif;">
        Contact Us
      </h1>
      <p class="text-lg text-gray-600 font-light text-center mb-12 leading-relaxed">
        Send us a message and we'll get back to you within one business day.
      </p>

      <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6">

        <!-- Paste your Web3Forms key between the quotes below -->
        <input type="hidden" name="access_key" value="PASTE_YOUR_KEY_HERE" />

        <!-- Optional: sets the subject of emails you receive -->
        <input type="hidden" name="subject" value="New contact form submission" />

        <div>
          <label class="block text-sm uppercase tracking-widest text-gray-600 mb-2">Name</label>
          <input
            type="text"
            name="name"
            required
            class="w-full border-b border-gray-300 py-2 focus:border-gray-900 focus:outline-none bg-transparent"
          />
        </div>

        <div>
          <label class="block text-sm uppercase tracking-widest text-gray-600 mb-2">Email</label>
          <input
            type="email"
            name="email"
            required
            class="w-full border-b border-gray-300 py-2 focus:border-gray-900 focus:outline-none bg-transparent"
          />
        </div>

        <div>
          <label class="block text-sm uppercase tracking-widest text-gray-600 mb-2"