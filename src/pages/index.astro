---
import '../styles/global.css';
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tashi's Web Design</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
      body { font-family: 'Montserrat', sans-serif; }
      .serif { font-family: 'Cormorant Garamond', serif; }
    </style>
  <script is:inline>
      (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
      Cal("init", {origin:"https://cal.com"});
    </script></head>
  <body class="bg-white text-gray-900">

    <header class="py-8">
      <div class="max-w-7xl mx-auto px-6 flex flex-col items-center gap-6">
        <a href="/">
  <img src="/images/tashilogo1.png" alt="Tashi's Web Design" width="150" />
</a>
        <nav class="flex gap-8 text-xs uppercase tracking-widest text-gray-700">
          <a href="/" class="hover:text-black">Home</a>
          
          <a href="/services" class="hover:text-black">Services</a>
          <a href="/products" class="hover:text-black">Products</a>
          <a href="/contact" class="hover:text-black">Contact</a>
          <a href="/about" class="hover:text-black">About</a>
        </nav>
      </div>
    </header>

<section class="relative h-[60vh] max-h-[600px] w-full overflow-hidden">
  <img src="/images/heros.jpg" alt="nature" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
        <div class="text-center text-white px-6">
          <p class="text-xs uppercase tracking-widest mb-4 opacity-90">Websites for Coaches, Consultants & Therapists</p>
          <h1 class="serif text-5xl md:text-6xl font-light mb-4">A website that books clients while you sleep</h1>
          <p class="text-sm md:text-base font-light tracking-wide max-w-xl mx-auto opacity-90 mb-8">Clean, professional websites with built-in booking — designed and launched in days, not months.</p>
          <button 
            data-cal-link="tashi"
            class="inline-block border border-white px-10 py-3 text-xs uppercase tracking-widest text-white hover:bg-white hover:text-black transition"
          >
            Book a Consultation
          </button>
        </div>
        
      </div>
    </section>

    <section class="max-w-2xl mx-auto text-center py-20 px-6">
<p class="text-xs uppercase tracking-widest text-gray-500 mb-5">Our Philosophy</p>
      <h2 class="serif text-4xl md:text-5xl font-light mb-6 leading-tight">Your work deserves more than a template</h2>
      <p class="text-base text-gray-600 leading-relaxed font-light">You help people change their lives. Your website should reflect the care you put into that work — not look like every other coach's site. We build simple, thoughtful websites that make prospects trust you before they even click "book a call."</p>
    </section>

    <section class="max-w-5xl mx-auto px-6 py-16 grid md:grid-cols-2 gap-12 items-center">
      <img src="/images/raw.jpg" alt="" class="w-full h-80 object-cover" />
      <div>
        <p class="text-xs uppercase tracking-widest text-gray-500 mb-4">Our Story</p>
        <h3 class="serif text-3xl md:text-4xl font-light mb-5 leading-tight">Personal attention, without the agency price tag</h3>
        <p class="text-sm text-gray-600 leading-relaxed font-light mb-6">Big agencies charge $5,000+ and take three months. DIY website builders leave you stuck configuring plugins at midnight. We sit in the middle — one person who actually talks to you, builds exactly what you need, and has your site live in days. No bloat, no templates, no surprises.</p>
      </div>
    </section>

    <section class="bg-stone-50 py-20">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-14">
          <p class="text-xs uppercase tracking-widest text-gray-500 mb-4">What We Offer</p>
          <h2 class="serif text-4xl md:text-5xl font-light">Services</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-10">
          <div class="text-center">
            <img src="/images/service1.jpg" alt="" class="w-full h-52 object-cover mb-5" />
            <h3 class="serif text-2xl font-light mb-3">Website Design & Build</h3>
            <p class="text-sm text-gray-600 font-light leading-relaxed">A beautiful, custom website that tells your story and converts visitors into clients. Mobile-friendly, fast, and live within a week.</p>
          </div>
          <div class="text-center">
            <img src="https://images.unsplash.com/photo-1524758631624-e2822e304c36?w=600&q=80" alt="" class="w-full h-52 object-cover mb-5" />
            <h3 class="serif text-2xl font-light mb-3">Booking & Scheduling Setup</h3>
            <p class="text-sm text-gray-600 font-light leading-relaxed">Let clients book consultations directly from your website. We connect Cal.com or Calendly to your calendar so you stop playing email tag.</p>
          </div>
          <div class="text-center">
            <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=600&q=80" alt="" class="w-full h-52 object-cover mb-5" />
            <h3 class="serif text-2xl font-light mb-3">Website Care & Updates</h3>
            <p class="text-sm text-gray-600 font-light leading-relaxed">Ongoing maintenance, content updates, and small design tweaks. Your site stays fresh, secure, and working — without you having to touch it.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="max-w-2xl mx-auto text-center py-20 px-6">
      <h2 class="serif text-4xl md:text-5xl font-light mb-6">Ready for a website that works as hard as you do?</h2>
      <p class="text-base text-gray-600 font-light mb-8">Book a free 20-minute call. We'll talk through your practice, your goals, and whether we're a good fit — no pressure, no sales pitch.</p>
      <button data-cal-link="tashi" class="inline-block border border-gray-900 px-10 py-3 text-xs uppercase tracking-widest hover:bg-gray-900 hover:text-white transition">
        Book a Free Call
      </button>
    </section>

    <footer class="border-t border-gray-200 py-10">
      <div class="max-w-6xl mx-auto px-6 text-center">
        <p class="serif text-2xl tracking-wider uppercase mb-5">Tashi's Web Design</p>
        <div class="flex justify-center gap-6 text-xs uppercase tracking-widest text-gray-600 mb-5">
          <a href="/" class="hover:text-black">Home</a>
          <a href="/about" class="hover:text-black">About</a>
          <a href="/services" class="hover:text-black">Services</a>
          <a href="/contact" class="hover:text-black">Contact</a>
        </div>
        <p class="text-xs text-gray-400 tracking-wider">&copy; 2026 Tashi's Web Design. All rights reserved.</p>
      </div>
    </footer>

  </body>
</html>