---
import '../styles/global.css';
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Products | Tashi's Web Design</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
      body { font-family: 'Montserrat', sans-serif; }
      .serif { font-family: 'Cormorant Garamond', serif; }
    </style>
  </head>
  <body class="bg-white text-gray-900">

    <!-- HEADER (copy from index.astro) -->
    <header class="py-8">
      <div class="max-w-7xl mx-auto px-6 flex flex-col items-center gap-6">
        <a href="/" class="serif text-3xl tracking-wider uppercase">Tashi's Web Design</a>
        <nav class="flex gap-8 text-xs uppercase tracking-widest text-gray-700">
          <a href="/" class="hover:text-black">Home</a>
          <a href="/services" class="hover:text-black">Services</a>
          <a href="/products" class="hover:text-black">Products</a>
          <a href="/contact" class="hover:text-black">Contact</a>
          <a href="/about" class="hover:text-black">About</a>
        </nav>
      </div>
    </header>

    <!-- PAGE HEADING -->
    <section class="max-w-3xl mx-auto text-center py-20 px-6">
      <p class="text-xs uppercase tracking-widest text-gray-500 mb-5">What We Offer</p>
      <h1 class="serif text-5xl md:text-6xl font-light mb-6 leading-tight">Packages</h1>
      <p class="text-base text-gray-600 leading-relaxed font-light">Low cost web package sales including hosting and web design.</p>
    </section>

    <!-- PRODUCT GRID -->
    <section class="max-w-5xl mx-auto px-6 pb-20">
      <div class="grid md:grid-cols-3 gap-10">
        
        <div class="text-center">
          <img src="/images/product1.jpg" alt="" class="w-full h-64 object-cover mb-5" />
          <h3 class="serif text-2xl font-light mb-3">Simple Presence</h3>
          <p class="text-sm text-gray-600 font-light leading-relaxed mb-4">\🌱 STARTER — "Simple Presence"
$150 (one-time setup)
What's included:

1-page custom website
Mobile-responsive design
Cal.com booking button integration
Contact form or email link
1 round of revisions
Delivered in 5-7 days</p>
          <p class="serif text-xl">$99</p>
        </div>

        <div class="text-center">
          <img src="/images/product2.jpg" alt="" class="w-full h-64 object-cover mb-5" />
          <h3 class="serif text-2xl font-light mb-3">Product Name</h3>
          <p class="text-sm text-gray-600 font-light leading-relaxed mb-4">Short description of what this product does and why people need it.</p>
          <p class="serif text-xl">$149</p>
        </div>

        <div class="text-center">
          <img src="/images/product3.jpg" alt="" class="w-full h-64 object-cover mb-5" />
          <h3 class="serif text-2xl font-light mb-3">Product Name</h3>
          <p class="text-sm text-gray-600 font-light leading-relaxed mb-4">Short description of what this product does and why people need it.</p>
          <p class="serif text-xl">$199</p>
        </div>

      </div>
    </section>

    <!-- FOOTER (copy from index.astro) -->
    <footer class="border-t border-gray-200 py-10">
      <div class="max-w-6xl mx-auto px-6 text-center">
        <p class="serif text-2xl tracking-wider uppercase mb-5">Tashi's Web Design</p>
        <div class="flex justify-center gap-6 text-xs uppercase tracking-widest text-gray-600 mb-5">
          <a href="/" class="hover:text-black">Home</a>
          <a href="/about" class="hover:text-black">About</a>
          <a href="/services" class="hover:text-black">Services</a>
          <a href="/products" class="hover:text-black">Products</a>
          <a href="/contact" class="hover:text-black">Contact</a>
        </div>
        <p class="text-xs text-gray-400 tracking-wider">&copy; 2026 Tashi's Web Design. All rights reserved.</p>
      </div>
    </footer>

  </body>
</html>